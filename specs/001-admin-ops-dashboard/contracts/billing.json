{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tenantra.test/contracts/billing.json",
  "title": "Billing API",
  "description": "Contracts for billing cycle and invoice management in Tenantra",
  "type": "object",
  "properties": {
    "GenerateInvoicesRequest": {
      "type": "object",
      "required": ["billingMonth", "dryRun"],
      "properties": {
        "billingMonth": {
          "type": "string",
          "format": "date",
          "description": "First day of the billing month (YYYY-MM-DD)."
        },
        "dryRun": {
          "type": "boolean",
          "description": "If true, report expected invoices without persisting."
        }
      }
    },
    "GenerateInvoicesResponse": {
      "type": "object",
      "required": ["generated", "skipped", "durationSeconds"],
      "properties": {
        "generated": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["unitId", "invoiceId", "amountDue"],
            "properties": {
              "unitId": { "type": "string", "format": "uuid" },
              "invoiceId": { "type": "string", "format": "uuid" },
              "amountDue": { "type": "number", "minimum": 0 },
              "status": {
                "type": "string",
                "enum": ["pending", "partial", "paid", "overdue"]
              }
            }
          }
        },
        "skipped": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["unitId", "reason"],
            "properties": {
              "unitId": { "type": "string", "format": "uuid" },
              "reason": { "type": "string" }
            }
          }
        },
        "durationSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "RecordPaymentRequest": {
      "type": "object",
      "required": ["invoiceId", "amount", "source", "paidAt"],
      "properties": {
        "invoiceId": { "type": "string", "format": "uuid" },
        "amount": { "type": "number", "exclusiveMinimum": 0 },
        "currency": { "type": "string", "default": "PHP" },
        "source": {
          "type": "string",
          "enum": ["manual", "stripe", "paymongo"]
        },
        "referenceCode": { "type": "string" },
        "paidAt": { "type": "string", "format": "date-time" }
      }
    },
    "RecordPaymentResponse": {
      "type": "object",
      "required": ["paymentId", "invoiceStatus"],
      "properties": {
        "paymentId": { "type": "string", "format": "uuid" },
        "invoiceStatus": {
          "type": "string",
          "enum": ["pending", "partial", "paid", "overdue"]
        }
      }
    }
  }
}
