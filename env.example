# Tenantra root environment template
# Copy to `.env` and fill before running the stack

# Database connection for Prisma (packages/db)
DATABASE_URL=postgresql://username:password@localhost:5432/tenantra

# Email provider (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@tenantra.local

# Storage (Supabase or S3-compatible)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=tenantra-files

# Billing integrations
STRIPE_SECRET_KEY=
PAYMONGO_SECRET_KEY=

# General
LOG_LEVEL=info
NEXTAUTH_SECRET=
