# Tenantra Admin Web App environment template
# Copy to `.env` and configure before running the web app

# Application
NEXT_PUBLIC_APP_NAME=Tenantra Admin Dashboard
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Authentication providers
NEXTAUTH_ADMIN_EMAIL=admin@tenantra.local
NEXTAUTH_ADMIN_PASSWORD=

# API routes
API_BASE_URL=http://localhost:3000/api
BILLING_WEBHOOK_SECRET=
ANNOUNCEMENTS_WEBHOOK_SECRET=

# Integrations
RESEND_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYMONGO_PUBLIC_KEY=

# Analytics & telemetry
SENTRY_DSN=
LOG_LEVEL=info
